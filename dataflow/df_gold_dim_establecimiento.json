{
	"name": "df_gold_dim_establecimiento",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_vacunaciones_consolidadas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          zona as string,",
				"          tiene_cadena_frio as boolean,",
				"          canal_origen as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    v.establecimiento_id,\\n    v.nombre_establecimiento,\\n    e.tipo_establecimiento,\\n    v.departamento,\\n    e.municipio,\\n    e.zona,\\n    CAST(e.tiene_cadena_frio AS BIT) AS tiene_cadena_frio,\\n    v.canal_origen\\nFROM silver.vacunaciones_consolidadas v\\nLEFT JOIN silver.catalogo_establecimientos e\\n    ON v.establecimiento_id = e.establecimiento_id\\nWHERE v.establecimiento_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          zona as string,",
				"          tiene_cadena_frio as boolean,",
				"          canal_origen as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          departamento,",
				"          municipio,",
				"          zona,",
				"          tiene_cadena_frio,",
				"          canal_origen",
				"     )) ~> sink1"
			]
		}
	}
}