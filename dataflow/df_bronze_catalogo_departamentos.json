{
	"name": "df_bronze_catalogos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "catalogo_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "catalogo_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "sink3"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 derive(municipio_id = trim(municipio_id),",
				"          municipio_nombre = initCap(trim(municipio_nombre)),",
				"          departamento = initCap(trim(departamento)),",
				"          codigo_departamento = upper(trim(codigo_departamento)),",
				"          zona_geografica = initCap(trim(zona_geografica)),",
				"          es_capital_departamental = toBoolean(toString(es_capital_departamental))) ~> derivedColumn1",
				"source2 derive(establecimiento_id = trim(establecimiento_id),",
				"          nombre_establecimiento = trim(nombre_establecimiento),",
				"          tipo_establecimiento = initCap(trim(tipo_establecimiento)),",
				"          zona = initCap(trim(zona)),",
				"          departamento = initCap(trim(departamento)),",
				"          municipio = initCap(trim(municipio)),",
				"          tiene_cadena_frio = toBoolean(toString(tiene_cadena_frio)),",
				"          activo = toBoolean(toString(activo))) ~> derivedColumn2",
				"source3 derive(vacuna_id = trim(vacuna_id),",
				"          vacuna_nombre = trim(vacuna_nombre),",
				"          intervalo_minimo_dias = iif(\r",
				"    isNull(intervalo_minimo_dias),\r",
				"    0,\r",
				"    toInteger(intervalo_minimo_dias, '##', 'en-US')\r",
				"),",
				"          condicion_especial = iifNull(condicion_especial, '')) ~> derivedColumn3",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          municipio_id,",
				"          municipio_nombre,",
				"          departamento,",
				"          codigo_departamento,",
				"          zona_geografica,",
				"          es_capital_departamental,",
				"          poblacion_depto_estimada",
				"     )) ~> sink1",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     )) ~> sink2",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          enfermedad_previene,",
				"          grupo_pai,",
				"          numero_dosis,",
				"          dosis_descripcion,",
				"          edad_aplicacion_descripcion,",
				"          edad_minima_dias,",
				"          edad_maxima_dias,",
				"          intervalo_minimo_dias,",
				"          via_administracion,",
				"          sitio_aplicacion,",
				"          dosis_ml,",
				"          condicion_especial",
				"     )) ~> sink3"
			]
		}
	}
}