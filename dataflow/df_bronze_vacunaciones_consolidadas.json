			"scriptLines": [
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 derive(registro_id = trim(registro_id),",
				"          paciente_id = trim(paciente_id),",
				"          ci_paciente = trim(ci_paciente),",
				"          nombre_paciente = initCap(trim(nombre_paciente)),",
				"          apellido_paterno = initCap(trim(apellido_paterno)),",
				"          apellido_materno = initCap(trim(apellido_materno)),",
				"          municipio_residencia = initCap(trim(municipio_residencia))) ~> derivedColumn1",
				"derivedColumn1 derive(sexo = upper(trim(sexo)),",
				"          departamento = case(\r",
				"    in(['Santa Cruz','Sta Cruz de la Sierra','Sta Cruz','Sta. Cruz',\r",
				"        'santa cruz','SantaCruz','SANTA CRUZ','SANTA  CRUZ',' Santa Cruz',\r",
				"        'Santa Cruz '], trim(departamento)),\r",
				"    'Santa Cruz',\r",
				"    trim(departamento)\r",
				"  )) ~> derivedColumn2",
				"derivedColumn2 derive(fecha_nacimiento = iif(\r",
				"    isNull(fecha_nacimiento),\r",
				"    toDate('1900-01-01'),\r",
				"    toDate(trim(fecha_nacimiento), 'dd/MM/yyyy')\r",
				"),",
				"          fecha_vacunacion = iif(\r",
				"    isNull(fecha_vacunacion),\r",
				"    toDate('1900-01-01'),\r",
				"    toDate(trim(fecha_vacunacion), 'dd/MM/yyyy', 'es-ES')\r",
				")) ~> derivedColumn3",
				"derivedColumn3 derive(comunidad_indigena = toBoolean(toString(comunidad_indigena)),",
				"          aplicacion_oportuna = toBoolean(toString(aplicacion_oportuna))) ~> derivedColumn4",
				"derivedColumn4 derive(temperatura_conservacion = toFloat(temperatura_conservacion),",
				"          lote_vacuna =  iif(\r",
				"    regexMatch(trim(lote_vacuna), '^\\\\d+$'),\r",
				"    concat('LOT-SC-', trim(lote_vacuna)),\r",
				"    trim(lote_vacuna)\r",
				"  ),",
				"          canal_origen = 'Santa Cruz',",
				"          numero_dosis = toInteger(numero_dosis)) ~> derivedColumn5",
				"derivedColumn5 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion,",
				"          canal_origen",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 aggregate(groupBy(registro_id),",
				"     paciente_id = first(paciente_id),",
				"          ci_paciente = first(ci_paciente),",
				"          nombre_paciente = first(nombre_paciente),",
				"          apellido_paterno = first(apellido_paterno),",
				"          apellido_materno = first(apellido_materno),",
				"          sexo = first(sexo),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          municipio_residencia = first(municipio_residencia),",
				"          comunidad_indigena = first(comunidad_indigena),",
				"          fecha_vacunacion = first(fecha_vacunacion),",
				"          vacuna_id = first(vacuna_id),",
				"          vacuna_nombre = first(vacuna_nombre),",
				"          numero_dosis = first(numero_dosis),",
				"          establecimiento_id = first(establecimiento_id),",
				"          nombre_establecimiento = first(nombre_establecimiento),",
				"          departamento = first(departamento),",
				"          lote_vacuna = first(lote_vacuna),",
				"          temperatura_conservacion = first(temperatura_conservacion),",
				"          edad_dias_aplicacion = first(edad_dias_aplicacion),",
				"          aplicacion_oportuna = first(aplicacion_oportuna),",
				"          via_administracion = first(via_administracion),",
				"          canal_origen = first(canal_origen)) ~> aggregate1",
				"aggregate1 filter(!isNull(fecha_vacunacion)) ~> filter1",
				"source2 derive(id_registro = trim(id_registro),",
				"          cod_paciente = trim(cod_paciente),",
				"          documento_identidad = trim(documento_identidad),",
				"          nombres = initCap(trim(nombres)),",
				"          primer_apellido = initCap(trim(primer_apellido)),",
				"          segundo_apellido = initCap(trim(segundo_apellido)),",
				"          municipio = initCap(trim(municipio))) ~> derivedColumn6",
				"derivedColumn6 derive(genero = case(\r",
				"    lower(trim(genero)) == 'femenino', 'F',\r",
				"    lower(trim(genero)) == 'masculino', 'M',\r",
				"    upper(trim(genero))\r",
				"  ),",
				"          depto = case(\r",
				"    in(['La Paz','La Paz ','LA PAZ','L.P.','Depto. La Paz',\r",
				"        'la paz','LaPaz',' La Paz','La  Paz'], trim(depto)),\r",
				"    'La Paz',\r",
				"    trim(depto)\r",
				"  )) ~> derivedColumn7",
				"derivedColumn7 derive(fec_nacimiento = coalesce(\r",
				"    toDate(trim(fec_nacimiento), 'dd/MM/yyyy'),\r",
				"    toDate(trim(fec_nacimiento), 'yyyy-MM-dd')\r",
				"  ),",
				"          fec_vacunacion = coalesce(\r",
				"    toDate(trim(fec_vacunacion), 'dd/MM/yyyy'),\r",
				"    toDate(trim(fec_vacunacion), 'yyyy-MM-dd')\r",
				"  )) ~> derivedColumn8",
				"derivedColumn8 derive(pueblo_indigena = iif(lower(trim(pueblo_indigena)) == 'sí' || lower(trim(pueblo_indigena)) == 'si', true(), false())) ~> derivedColumn9",
				"derivedColumn9 derive(temp_conservacion = toFloat(temp_conservacion),",
				"          nro_lote = trim(nro_lote),",
				"          aplicacion_oportuna = toBoolean(''),",
				"          canal_origen = 'La Paz',",
				"          nro_dosis = toInteger(nro_dosis)) ~> derivedColumn10",
				"derivedColumn10 select(mapColumn(",
				"          registro_id = id_registro,",
				"          paciente_id = cod_paciente,",
				"          ci_paciente = documento_identidad,",
				"          nombre_paciente = nombres,",
				"          apellido_paterno = primer_apellido,",
				"          apellido_materno = segundo_apellido,",
				"          sexo = genero,",
				"          fecha_nacimiento = fec_nacimiento,",
				"          municipio_residencia = municipio,",
				"          comunidad_indigena = pueblo_indigena,",
				"          fecha_vacunacion = fec_vacunacion,",
				"          vacuna_id = cod_vacuna,",
				"          vacuna_nombre = desc_vacuna,",
				"          numero_dosis = nro_dosis,",
				"          establecimiento_id = cod_establecimiento,",
				"          nombre_establecimiento = desc_establecimiento,",
				"          departamento = depto,",
				"          lote_vacuna = nro_lote,",
				"          temperatura_conservacion = temp_conservacion,",
				"          edad_dias_aplicacion = edad_dias,",
				"          via_administracion = via_aplicacion,",
				"          aplicacion_oportuna,",
				"          canal_origen",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 aggregate(groupBy(registro_id),",
				"     paciente_id = first(paciente_id),",
				"          ci_paciente = first(ci_paciente),",
				"          nombre_paciente = first(nombre_paciente),",
				"          apellido_paterno = first(apellido_paterno),",
				"          apellido_materno = first(apellido_materno),",
				"          sexo = first(sexo),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          municipio_residencia = first(municipio_residencia),",
				"          comunidad_indigena = first(comunidad_indigena),",
				"          fecha_vacunacion = first(fecha_vacunacion),",
				"          vacuna_id = first(vacuna_id),",
				"          vacuna_nombre = first(vacuna_nombre),",
				"          numero_dosis = first(numero_dosis),",
				"          establecimiento_id = first(establecimiento_id),",
				"          nombre_establecimiento = first(nombre_establecimiento),",
				"          departamento = first(departamento),",
				"          lote_vacuna = first(lote_vacuna),",
				"          temperatura_conservacion = first(temperatura_conservacion),",
				"          edad_dias_aplicacion = first(edad_dias_aplicacion),",
				"          via_administracion = first(via_administracion),",
				"          aplicacion_oportuna = first(aplicacion_oportuna),",
				"          canal_origen = first(canal_origen)) ~> aggregate2",
				"aggregate2 filter(!isNull(fecha_vacunacion)) ~> filter2",
				"source3 derive(record_id = trim(record_id),",
				"          patient_id = trim(iifNull(patient_id, 'SIN-ID')),",
				"          patient_ci = trim(iifNull(patient_ci, 'SIN-CI')),",
				"          patient_name = initCap(trim(patient_name)),",
				"          patient_last_name_1 = initCap(trim(patient_last_name_1)),",
				"          patient_last_name_2 = initCap(trim(patient_last_name_2)),",
				"          patient_municipality = initCap(trim(patient_municipality))) ~> derivedColumn11",
				"derivedColumn11 derive(patient_sex =  upper(trim(patient_sex)),",
				"          patient_indigenous = toBoolean(toString(patient_indigenous))) ~> derivedColumn12",
				"derivedColumn12 derive(patient_birth_date = toDate(trim(patient_birth_date), 'yyyy-MM-dd'),",
				"          vaccination_date = toDate(\r",
				"    iif(\r",
				"        isNull(vaccination_date),\r",
				"        '1900-01-01',\r",
				"        left(trim(vaccination_date), 10)\r",
				"    ),\r",
				"    'yyyy-MM-dd'\r",
				")) ~> derivedColumn13",
				"derivedColumn13 derive(vaccine_code = trim(iifNull(vaccine_code, 'SIN-VACUNA')),",
				"          vaccine_name = trim(iifNull(vaccine_name, 'Desconocida')),",
				"          dose_number = iif(isNull(dose_number), 0, toInteger(dose_number)),",
				"          facility_code = trim(iifNull(facility_code, 'EST-DESCONOCIDO')),",
				"          facility_name = trim(iifNull(facility_name, 'Desconocido')),",
				"          storage_temp_celsius = toFloat(storage_temp_celsius)) ~> derivedColumn14",
				"derivedColumn14 derive(lot_number = iif(\r",
				"    regexMatch(trim(lot_number), '^\\\\d+$'),\r",
				"    concat('LOT-MOV-', trim(lot_number)),\r",
				"    trim(lot_number)\r",
				"  ),",
				"          aplicacion_oportuna = toBoolean(''),",
				"          patient_department = initCap(trim(patient_department)),",
				"          patient_municipality = initCap(trim(patient_municipality)),",
				"          canal_origen = 'Rural') ~> derivedColumn15",
				"select3 aggregate(groupBy(registro_id),",
				"     paciente_id = first(paciente_id),",
				"          ci_paciente = first(ci_paciente),",
				"          nombre_paciente = first(nombre_paciente),",
				"          apellido_paterno = first(apellido_paterno),",
				"          apellido_materno = first(apellido_materno),",
				"          sexo = first(sexo),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          departamento = first(departamento),",
				"          municipio_residencia = first(municipio_residencia),",
				"          comunidad_indigena = first(comunidad_indigena),",
				"          fecha_vacunacion = first(fecha_vacunacion),",
				"          vacuna_id = first(vacuna_id),",
				"          vacuna_nombre = first(vacuna_nombre),",
				"          numero_dosis = first(numero_dosis),",
				"          establecimiento_id = first(establecimiento_id),",
				"          nombre_establecimiento = first(nombre_establecimiento),",
				"          lote_vacuna = first(lote_vacuna),",
				"          temperatura_conservacion = first(temperatura_conservacion),",
				"          edad_dias_aplicacion = first(edad_dias_aplicacion),",
				"          via_administracion = first(via_administracion),",
				"          aplicacion_oportuna = first(aplicacion_oportuna),",
				"          canal_origen = first(canal_origen)) ~> aggregate3",
				"aggregate3 filter(!isNull(fecha_vacunacion) && vacuna_id != 'SIN-VACUNA') ~> filter3",
				"derivedColumn15 select(mapColumn(",
				"          registro_id = record_id,",
				"          paciente_id = patient_id,",
				"          ci_paciente = patient_ci,",
				"          nombre_paciente = patient_name,",
				"          apellido_paterno = patient_last_name_1,",
				"          apellido_materno = patient_last_name_2,",
				"          sexo = patient_sex,",
				"          fecha_nacimiento = patient_birth_date,",
				"          departamento = patient_department,",
				"          municipio_residencia = patient_municipality,",
				"          comunidad_indigena = patient_indigenous,",
				"          fecha_vacunacion = vaccination_date,",
				"          vacuna_id = vaccine_code,",
				"          vacuna_nombre = vaccine_name,",
				"          numero_dosis = dose_number,",
				"          establecimiento_id = facility_code,",
				"          nombre_establecimiento = facility_name,",
				"          lote_vacuna = lot_number,",
				"          temperatura_conservacion = storage_temp_celsius,",
				"          edad_dias_aplicacion = patient_age_days,",
				"          via_administracion = administration_route,",
				"          aplicacion_oportuna,",
				"          canal_origen",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"filter1, filter2 union(byName: true)~> union1",
				"union1, filter3 union(byName: true)~> union2",
				"union2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as integer,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as decimal(4,1),",
				"          edad_dias_aplicacion as integer,",
				"          aplicacion_oportuna as boolean,",
				"          via_administracion as string,",
				"          canal_origen as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
